# Sentinel AI — Frontend environment variables
# Copy to .env.local for local development (never commit .env.local)

# Base URL of the FastAPI backend (no trailing slash)
# Leave empty to run in full mock mode (no backend calls)
VITE_API_URL=https://sentinelaibe-production.up.railway.app

# Shared secret for backend API authentication.
# Must match API_SECRET set in Railway env vars.
# Generate a new one: python3 -c "import secrets; print('ssk_' + secrets.token_hex(32))"
VITE_API_SECRET=ssk_66553f0be2dffee4bd27e48924562831ffdbffcbc6606713ce5c1aa1ea2f091e
